# AI-KS 运行环境示例。
# 使用方式：复制为仓库根目录的 .env，然后按服务器实际情况修改。
#
# 重要说明：
# - API 和前端都会读取仓库根目录 .env。
# - .env 不应提交到 Git；这里的 .env.example 只保存示例和说明。
# - 远程服务器测试时，如果浏览器不是运行在服务器本机，VITE_API_BASE_URL 不建议写 localhost。

# API 服务监听端口。NestJS 启动后会监听这个端口，接口前缀为 /api。
API_PORT=8007

# Web 服务监听端口。Vite dev 或 PM2 静态服务会使用这个端口。
WEB_PORT=8008

# PM2 静态 Web 服务绑定地址。0.0.0.0 表示允许外部访问服务器端口。
WEB_HOST=0.0.0.0

# PM2 Web 进程转发 /api 时使用的内部 API 地址。
# 留空时脚本默认使用 http://127.0.0.1:<API_PORT>。
# 如果 API 和 Web 不在同一台机器，再打开并改成实际地址。
# API_PROXY_ORIGIN=http://127.0.0.1:8007

# 前端浏览器请求 API 的基础地址。
# - 本机调试可用 http://localhost:8007/api。
# - PM2/反向代理部署更推荐 /api，避免远程浏览器把 localhost 当成本机。
VITE_API_BASE_URL=http://localhost:8007/api

# API 启动时是否主动连接数据库。
# false 表示按请求需要连接；true 表示启动时就连接，数据库不可用会直接启动失败。
PRISMA_CONNECT_ON_BOOT=false

# API 启动时是否检查数据库表结构是否和 Prisma schema 一致。
# 正常测试建议保持 true；只有维护窗口或临时排障时才考虑改成 false。
PRISMA_SCHEMA_CHECK_ON_BOOT=true

# 普通用户 JWT 密钥。远程测试/生产必须替换为随机长字符串。
JWT_SECRET=replace-with-a-long-random-secret

# 普通用户 JWT 有效期。
JWT_EXPIRES_IN=7d

# 超级管理员默认账号。远程测试前建议修改密码。
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456

# 超级管理员 JWT 密钥。远程测试/生产必须替换为随机长字符串。
ADMIN_JWT_SECRET=replace-with-a-long-random-admin-secret

# 超级管理员 JWT 有效期。
ADMIN_JWT_EXPIRES_IN=7d

# 代理端 JWT 密钥。远程测试/生产必须替换为随机长字符串。
AGENT_JWT_SECRET=replace-with-a-long-random-agent-secret

# 代理端 JWT 有效期。
AGENT_JWT_EXPIRES_IN=7d

# 快手接口模式。
# mock：使用模拟数据，适合普通远程测试。
# real：使用真实快手接口，需要配置下面的快手 token/广告主等信息。
KUAISHOU_API_MODE=mock

# PostgreSQL 数据库连接地址。
# 格式：postgresql://用户名:密码@主机:端口/数据库名?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_ks?schema=public"

# 是否自动初始化 demo 数据。
# 远程真实流程测试通常建议 false，避免自动插入演示数据。
DEMO_AUTO_SEED=false

# 仅当 KUAISHOU_API_MODE=real 时需要。
# 快手 Marketing API access token。
KUAISHOU_ACCESS_TOKEN=

# 仅当 KUAISHOU_API_MODE=real 时需要。
# 快手广告主 ID。
KUAISHOU_ADVERTISER_ID=

# 保存快手平台 secret 到数据库前建议配置。
# 需要稳定的 32 字节 base64 值；变更后，旧数据里已加密保存的 secret 将无法解密。
KUAISHOU_TOKEN_ENCRYPTION_KEY=
