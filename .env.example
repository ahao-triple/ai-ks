# AI-KS server and web client read runtime settings from the repo-root .env.
# Copy this file to .env before running pnpm dev, pnpm dev:api, or pnpm dev:web.
API_PORT=3000
WEB_PORT=5173
VITE_API_BASE_URL=/api
PRISMA_CONNECT_ON_BOOT=false
PRISMA_SCHEMA_CHECK_ON_BOOT=true
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456
ADMIN_JWT_SECRET=replace-with-a-long-random-admin-secret
ADMIN_JWT_EXPIRES_IN=7d
AGENT_JWT_SECRET=replace-with-a-long-random-agent-secret
KUAISHOU_API_MODE=mock
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_ks?schema=public"
DEMO_AUTO_SEED=true

# Required only when KUAISHOU_API_MODE=real.
KUAISHOU_ACCESS_TOKEN=
KUAISHOU_ADVERTISER_ID=
# Recommended before storing Kuaishou platform secrets in the database.
# Use a stable 32-byte base64 value; changing it prevents decrypting existing stored secrets.
KUAISHOU_TOKEN_ENCRYPTION_KEY=
